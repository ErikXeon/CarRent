<Window x:Class="CarRent.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
       Title="CityDrive"
        Height="760"
        Width="1280"
        MinHeight="680"
        MinWidth="1150"
        WindowStartupLocation="CenterScreen"
        Background="#F2F5FA">
    <Window.Resources>
        <LinearGradientBrush x:Key="BackgroundGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F4F8FF" Offset="0" />
            <GradientStop Color="#E8EEF9" Offset="0.5" />
            <GradientStop Color="#F7F9FD" Offset="1" />
        </LinearGradientBrush>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="#2F6FEB" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="11">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource BackgroundGradient}" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="18" Padding="20" Margin="0,0,0,14" BorderBrush="#DCE5F4" BorderThickness="1">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Left" Orientation="Vertical">
                    <TextBlock Text="CityDrive" FontSize="30" FontWeight="Bold" Foreground="#1F2A44" />
                    <TextBlock Text="Выбирай авто, бронируй или сразу стартуй аренду" FontSize="14" Foreground="#60749D" Margin="0,6,0,0" />
                </StackPanel>
                <Border DockPanel.Dock="Right" Background="#EEF3FF" CornerRadius="12" Padding="12,8">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Статус:" Foreground="#5D7096" FontSize="13" Margin="0,0,8,0" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding HeaderStatus}" Foreground="#1F2A44" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.35*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Padding="0,0,14,0">
                <ItemsControl ItemsSource="{Binding Cars}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="320"
                                    Margin="0,0,14,14"
                                    Padding="14"
                                    Background="White"
                                    BorderBrush="#D6E0F1"
                                    BorderThickness="1"
                                    CornerRadius="16">
                                <StackPanel>
                                    <Border Background="#EAF0FD" CornerRadius="10" Padding="8" HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding ClassTag}" Foreground="#3C4E76" FontSize="12" FontWeight="SemiBold" />
                                    </Border>
                                    <TextBlock Text="{Binding Name}" Foreground="#1E2B47" FontWeight="Bold" FontSize="22" Margin="0,14,0,2" />
                                    <TextBlock Text="{Binding BatteryText}" Foreground="#58719F" FontSize="13" />
                                    <TextBlock Text="{Binding Location}" Foreground="#647DA8" FontSize="13" Margin="0,2,0,10" />

                                    <Grid Margin="0,2,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Background="#F1F5FF" CornerRadius="10" Padding="8" Margin="0,0,6,0">
                                            <StackPanel>
                                                <TextBlock Text="Цена / мин" FontSize="12" Foreground="#6985B8" />
                                                <TextBlock Text="{Binding PricePerMinuteText}" FontSize="20" FontWeight="Bold" Foreground="#1E2B47" />
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Column="1" Background="#F1F5FF" CornerRadius="10" Padding="8" Margin="6,0,0,0">
                                            <StackPanel>
                                                <TextBlock Text="Рейтинг" FontSize="12" Foreground="#6985B8" />
                                                <TextBlock Text="{Binding RatingText}" FontSize="20" FontWeight="Bold" Foreground="#1E2B47" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <Button Content="Выбрать"
                                            Command="{Binding DataContext.SelectCarCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            Background="#2F6FEB" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Border Grid.Column="1"
                    Padding="18"
                    CornerRadius="16"
                    Background="White"
                    BorderThickness="1"
                    BorderBrush="#D6E0F1">
                <StackPanel>
                    <TextBlock Text="Панель поездки" Foreground="#1F2A44" FontSize="24" FontWeight="Bold" />
                    <TextBlock Text="{Binding SelectedCarName}" Foreground="#58719F" FontSize="14" Margin="0,6,0,14" TextWrapping="Wrap"/>

                    <Border Background="#F3F7FF" Padding="12" CornerRadius="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Текущий этап" Foreground="#6A82AF" FontSize="12" />
                            <TextBlock Text="{Binding StageText}" Foreground="#1F2A44" FontSize="18" FontWeight="Bold" />
                            <TextBlock Text="{Binding TimerText}" Foreground="#3B6EC9" FontSize="14" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Background="#F3F7FF" Padding="12" CornerRadius="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Промежуточный расчет" Foreground="#6A82AF" FontSize="12" />
                            <TextBlock Text="{Binding RunningTotalText}" Foreground="#1F2A44" FontSize="18" FontWeight="Bold" />
                            <TextBlock Text="{Binding BillingHint}" Foreground="#6780AC" FontSize="12" TextWrapping="Wrap" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>

                    <Button Content="1) Забронировать (15 минут)" Command="{Binding ReserveCommand}" Background="#2F6FEB" />
                    <Button Content="2) Запустить двигатель" Command="{Binding StartEngineCommand}" Background="#2F6FEB" />
                    <Button Content="3) Начать аренду" Command="{Binding StartRideCommand}" Background="#2F6FEB" />
                    <Button Content="4) Завершить и оплатить" Command="{Binding FinishAndPayCommand}" Background="#F47D37" />

                    <Border Background="#F9FBFF" CornerRadius="10" Padding="12" Margin="0,6,0,0" BorderBrush="#DCE5F4" BorderThickness="1">
                        <TextBlock Text="{Binding ReceiptText}" Foreground="#31456D" FontSize="13" TextWrapping="Wrap" />
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
