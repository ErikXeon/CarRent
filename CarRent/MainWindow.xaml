<Window x:Class="CarRent.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
       Title="CityDrive"
        Height="760"
        Width="1280"
        MinHeight="680"
        WindowState="Maximized"
        MinWidth="1150"
        WindowStartupLocation="CenterScreen"
        Background="#DCE8FA">
    <Window.Resources>
        <LinearGradientBrush x:Key="BackgroundGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#DCE8FA" Offset="0" />
            <GradientStop Color="#CFE1FA" Offset="0.45" />
            <GradientStop Color="#E2ECFD" Offset="1" />
        </LinearGradientBrush>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="#2E62C6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="11">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource BackgroundGradient}" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#EEF4FF" CornerRadius="18" Padding="20" Margin="0,0,0,14" BorderBrush="#BFD0EE" BorderThickness="1">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Left" Orientation="Vertical">
                    <TextBlock Text="CityDrive" FontSize="30" FontWeight="Bold" Foreground="#1E3463" />
                    <TextBlock Text="Выбирай авто, бронируй или сразу стартуй аренду" FontSize="14" Foreground="#3F5D94" Margin="0,6,0,0" />
                </StackPanel>
                <Border DockPanel.Dock="Right" Background="#DDEAFF" CornerRadius="12" Padding="12,8">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Статус:" Foreground="#3F5D94" FontSize="13" Margin="0,0,8,0" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding HeaderStatus}" Foreground="#1E3463" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.4*" />
                <ColumnDefinition Width="0.82*" />
                <ColumnDefinition Width="0.9*" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Padding="0,0,14,0">
                <ItemsControl ItemsSource="{Binding FilteredCars}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="270"
                                    Margin="0,0,12,12"
                                    Padding="12"
                                    Background="#F3F7FF"
                                    BorderBrush="#BFD0EE"
                                    BorderThickness="1"
                                    CornerRadius="16">
                                <StackPanel>
                                    <Border Background="#DDEAFF" CornerRadius="10" Padding="8" HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding ClassTag}" Foreground="#2F4B7E" FontSize="12" FontWeight="SemiBold" />
                                    </Border>
                                    <TextBlock Text="{Binding Name}" Foreground="#1A335F" FontWeight="Bold" FontSize="20" Margin="0,12,0,2" />
                                    <Border Background="#FFFFFF" Padding="8" CornerRadius="10" Margin="0,4,0,8" BorderBrush="#C6D8F7" BorderThickness="1">
                                        <Image Source="{Binding ImagePath}" Height="110" Stretch="Uniform" />
                                    </Border>
                                    <TextBlock Text="{Binding BatteryText}" Foreground="#3D5A8F" FontSize="13" />
                                    <TextBlock Text="{Binding Location}" Foreground="#4E699A" FontSize="13" Margin="0,2,0,10" />

                                    <Grid Margin="0,2,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Background="#E8F0FF" CornerRadius="10" Padding="8" Margin="0,0,6,0">
                                            <StackPanel>
                                                <TextBlock Text="Цена / мин" FontSize="12" Foreground="#4F6FA6" />
                                                <TextBlock Text="{Binding PricePerMinuteText}" FontSize="18" FontWeight="Bold" Foreground="#1A335F" />
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Column="1" Background="#E8F0FF" CornerRadius="10" Padding="8" Margin="6,0,0,0">
                                            <StackPanel>
                                                <TextBlock Text="Рейтинг" FontSize="12" Foreground="#4F6FA6" />
                                                <TextBlock Text="{Binding RatingText}" FontSize="18" FontWeight="Bold" Foreground="#1A335F" />
                                                <TextBlock Text="{Binding ReviewsCountText}" FontSize="11" Foreground="#627FAF" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <Button Content="Выбрать"
                                            Command="{Binding DataContext.SelectCarCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            Background="#2E62C6" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Border Grid.Column="1"
                    Padding="14"
                    CornerRadius="16"
                    Background="#EEF4FF"
                    BorderThickness="1"
                    BorderBrush="#BFD0EE"
                    Margin="0,0,14,0">
                <StackPanel>
                    <TextBlock Text="Фильтры" Foreground="#1E3463" FontSize="20" FontWeight="Bold" />
                    <TextBlock Text="Подбери авто по цене, классу и рейтингу" Foreground="#4869A4" FontSize="11" Margin="0,4,0,12" TextWrapping="Wrap" />

                    <TextBlock Text="Класс" Foreground="#3F5D94" FontSize="12" Margin="0,0,0,6" />
                    <ComboBox ItemsSource="{Binding AvailableClasses}"
                              SelectedItem="{Binding SelectedClassFilter}"
                              Margin="0,0,0,12"
                              Padding="8,4" />

                    <Border Background="#FFFFFF" Padding="10" CornerRadius="10" Margin="0,0,0,10" BorderBrush="#C6D8F7" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Макс. цена" Foreground="#3F5D94" FontSize="12" />
                            <TextBlock Text="{Binding MaxPriceFilterText}" Foreground="#1E3463" FontWeight="Bold" FontSize="15" Margin="0,4,0,8" />
                            <Slider Minimum="0"
                                    Maximum="{Binding MaxPriceLimit}"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding MaxPriceFilter}" />
                        </StackPanel>
                    </Border>

                    <Border Background="#FFFFFF" Padding="10" CornerRadius="10" Margin="0,0,0,12" BorderBrush="#C6D8F7" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Мин. рейтинг" Foreground="#3F5D94" FontSize="12" />
                            <TextBlock Text="{Binding MinRatingFilterText}" Foreground="#1E3463" FontWeight="Bold" FontSize="15" Margin="0,4,0,8" />
                            <Slider Minimum="0"
                                    Maximum="5"
                                    TickFrequency="0.1"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding MinRatingFilter}" />
                        </StackPanel>
                    </Border>

                    <TextBlock Text="{Binding FiltersSummary}" Foreground="#4869A4" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,8" />
                    <Button Content="Сбросить фильтры" Command="{Binding ResetFiltersCommand}" Background="#4A86E8" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2"
                    Padding="14"
                    CornerRadius="16"
                    Background="#EEF4FF"
                    BorderThickness="1"
                    BorderBrush="#BFD0EE">
                <StackPanel>
                    <TextBlock Text="Панель поездки" Foreground="#1E3463" FontSize="21" FontWeight="Bold" />
                    <TextBlock Text="{Binding SelectedCarName}" Foreground="#3F5D94" FontSize="13" Margin="0,6,0,12" TextWrapping="Wrap"/>

                    <Border Background="#FFFFFF" Padding="10" CornerRadius="10" Margin="0,0,0,10" BorderBrush="#BFD0EE" BorderThickness="1">
                        <StackPanel>
                            <Image Source="{Binding SelectedCarImagePath}" Width="210" Height="150" Stretch="Uniform" />
                            <TextBlock Text="{Binding SelectedCarImageStatusText}" Foreground="#4869A4" FontSize="12" Margin="0,8,0,0" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Background="#DDEAFF" Padding="12" CornerRadius="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Текущий этап" Foreground="#4869A4" FontSize="12" />
                            <TextBlock Text="{Binding StageText}" Foreground="#1E3463" FontSize="18" FontWeight="Bold" />
                            <TextBlock Text="{Binding TimerText}" Foreground="#2E62C6" FontSize="14" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Background="#DDEAFF" Padding="12" CornerRadius="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Промежуточный расчет" Foreground="#4869A4" FontSize="12" />
                            <TextBlock Text="{Binding RunningTotalText}" Foreground="#1E3463" FontSize="18" FontWeight="Bold" />
                            <TextBlock Text="{Binding BillingHint}" Foreground="#4869A4" FontSize="12" TextWrapping="Wrap" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>

                    <Button Content="1) Забронировать (15 минут)" Command="{Binding ReserveCommand}" Background="#2E62C6" />
                    <Button Content="2) Запустить двигатель" Command="{Binding StartEngineCommand}" Background="#2E62C6" />
                    <Button Content="3) Начать аренду" Command="{Binding StartRideCommand}" Background="#2E62C6" />
                    <Button Content="4) Завершить и оплатить" Command="{Binding FinishAndPayCommand}" Background="#4A86E8" />

                    <Border Background="#EAF1FF" Padding="12" CornerRadius="10" Margin="0,4,0,10" BorderBrush="#BFD0EE" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Оценка поездки" Foreground="#4869A4" FontSize="12" />
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,6">
                                <Button Content="★1" Width="40" Margin="0,0,6,0" Padding="0" Height="30" Command="{Binding SetReviewStarsCommand}" CommandParameter="1" Background="#2E62C6" />
                                <Button Content="★2" Width="40" Margin="0,0,6,0" Padding="0" Height="30" Command="{Binding SetReviewStarsCommand}" CommandParameter="2" Background="#2E62C6" />
                                <Button Content="★3" Width="40" Margin="0,0,6,0" Padding="0" Height="30" Command="{Binding SetReviewStarsCommand}" CommandParameter="3" Background="#2E62C6" />
                                <Button Content="★4" Width="40" Margin="0,0,6,0" Padding="0" Height="30" Command="{Binding SetReviewStarsCommand}" CommandParameter="4" Background="#2E62C6" />
                                <Button Content="★5" Width="40" Margin="0,0,6,0" Padding="0" Height="30" Command="{Binding SetReviewStarsCommand}" CommandParameter="5" Background="#2E62C6" />
                            </StackPanel>
                            <TextBlock Text="{Binding PendingReviewText}" Foreground="#3F5D94" FontSize="12" Margin="0,0,0,6" />
                            <TextBlock Text="{Binding ReviewHint}" Foreground="#3F5D94" FontSize="12" Margin="0,0,0,6" TextWrapping="Wrap" />
                            <Button Content="Отправить отзыв" Command="{Binding SubmitReviewCommand}" Background="#2E62C6" />
                        </StackPanel>
                    </Border>

                    <Border Background="#EAF1FF" CornerRadius="10" Padding="12" Margin="0,6,0,0" BorderBrush="#BFD0EE" BorderThickness="1">
                        <TextBlock Text="{Binding ReceiptText}" Foreground="#2D4576" FontSize="13" TextWrapping="Wrap" />
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
